# Dive Vacation Planner - Environment Template
#
# Copy this file to .env and fill in real values before starting services.
#   cp .env.example .env
#
# Variables marked REQUIRED must be set.
# Variables with defaults can be left as-is for local development.

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------

# Connection string consumed by application services.
# For local dev this points at the Docker Compose postgres service.
DATABASE_URL=postgresql://diveuser:divepass@localhost:5432/divedb

# Individual connection fields (used by docker-compose and some adapters).
POSTGRES_USER=diveuser
POSTGRES_PASSWORD=divepass
POSTGRES_DB=divedb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis / BullMQ
# ---------------------------------------------------------------------------

# Connection string used by BullMQ workers and queue producers.
REDIS_URL=redis://localhost:6379

# Individual fields (used by docker-compose and direct ioredis clients).
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=            # leave blank to disable Redis AUTH locally
# REDIS_DB=0                 # optional: Redis DB index (default 0)

# ---------------------------------------------------------------------------
# MCP Server
# ---------------------------------------------------------------------------

# HTTP port for the MCP server process.
MCP_SERVER_PORT=3000

# Log level: error | warn | info | debug
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Worker process
# ---------------------------------------------------------------------------

# Concurrency for background crawl/enrichment workers.
WORKER_CONCURRENCY=2

# ---------------------------------------------------------------------------
# External integrations (fill in when implementing adapters)
# ---------------------------------------------------------------------------

# Flight provider credentials
# FLIGHT_PROVIDER_API_KEY=

# Accommodation provider credentials
# ACCOMMODATION_PROVIDER_API_KEY=

# Reddit research MCP endpoint (set when integrating reddit-research-mcp)
# REDDIT_RESEARCH_MCP_URL=

# Google Calendar OAuth credentials (optional integration)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
