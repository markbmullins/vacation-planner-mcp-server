# autodev Controller - Environment Template
#
# The autodev controller uses its own Redis connection separate from the
# application services, so it can be run independently.
#
# Copy to autodev/.env:
#   cp autodev/.env.example autodev/.env

# ---------------------------------------------------------------------------
# Redis connection for the autodev controller and pipeline workers
# These default to the same Redis instance started by docker-compose.
# ---------------------------------------------------------------------------
AUTODEV_REDIS_HOST=127.0.0.1
AUTODEV_REDIS_PORT=6379
# AUTODEV_REDIS_USERNAME=
# AUTODEV_REDIS_PASSWORD=
# AUTODEV_REDIS_DB=1       # use a different DB index to isolate from app queues
