    "reset-ticket": "tsx scripts/reset-ticket.ts",
    "stop-after-current": "tsx scripts/stop-after-current.ts",
    "resume": "tsx scripts/resume.ts"
  },
  "dependencies": {
    "bullmq": "^5",
    "dotenv": "^17.3.1",
    "ioredis": "^5"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "pm2": "^5.4.3",
    "tsx": "^4",
    "typescript": "^5.4.5"
  }
}
