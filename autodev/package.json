{
  "name": "autodev",
  "type": "module",
  "scripts": {
    "controller": "tsx controller.ts",
    "workers": "tsx workers/index.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build",
    "start": "node scripts/start.mjs",
    "stop": "pm2 delete autodev-opencode autodev-workers autodev-controller",
